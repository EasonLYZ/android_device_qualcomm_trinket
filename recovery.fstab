# Recovery 模式分区表
# A/B 系统分区（逻辑分区）
/system         ext4    /dev/block/mapper/system_a  flags=logical,slotselect,avb_keys,avb,display="System"
/system_ext     ext4    /dev/block/mapper/system_ext_a  flags=logical,slotselect,avb_keys,avb,display="System_Ext"
/product        ext4    /dev/block/mapper/product_a  flags=logical,slotselect,avb_keys,avb,display="Product"
/vendor         ext4    /dev/block/mapper/vendor_a  flags=logical,slotselect,avb_keys,avb,display="Vendor"

# 数据分区
/data           f2fs    /dev/block/by-name/userdata  flags=display="Data";avb;forcefdeorfbe;userdataresize
/metadata       ext4    /dev/block/by-name/metadata  flags=display="Metadata"

# 外置存储 (通常不变)
/sdcard         vfat    /dev/block/mmcblk1p1  flags=display="SDCard";storage;wipeingui;removable

# A/B 镜像分区
/boot           emmc    /dev/block/by-name/boot  flags=display="Boot"
/recovery       emmc    /dev/block/by-name/recovery  flags=display="Recovery"
/dtbo           emmc    /dev/block/by-name/dtbo  flags=display="DTBO"
/vbmeta         emmc    /dev/block/by-name/vbmeta  flags=display="VBMeta"
/misc           emmc    /dev/block/by-name/misc  flags=display="Misc"
/cache          ext4    /dev/block/by-name/cache  flags=display="Cache"
/persist        ext4    /dev/block/by-name/persist  flags=display="Persist"
/odm            ext4    /dev/block/by-name/odm  flags=display="ODM"

# 添加fastbootd支持的分区
/staging        emmc    /dev/block/by-name/staging  flags=display="Staging"